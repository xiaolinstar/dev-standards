{
  "name": "@your-scope/miniapp",
  "private": true,
  "version": "0.1.0",
  "description": "WeChat native miniapp (TypeScript) — from dev-standards template",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"miniprogram/**/*.ts\" \"scripts/**/*.mjs\" --max-warnings 0",
    "format": "prettier --write \"miniprogram/**/*.{ts,scss,json}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"miniprogram/**/*.{ts,scss,json}\" \"scripts/**/*.mjs\"",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "bump-version": "node scripts/bump-version.mjs",
    "secret-scan": "gitleaks detect --source . --no-git --redact --no-banner || gitleaks protect --staged --redact --no-banner"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "miniprogram-api-promise": "^1.0.4",
    "miniprogram-api-typings": "^3.12.3",
    "prettier": "3.3.3",
    "typescript": "^5.6.3"
  }
}
